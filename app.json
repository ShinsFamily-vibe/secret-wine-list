{
  "expo": {
    "name": "My Wine List",
    "slug": "wine-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.winelist.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We use your camera to scan wine labels.",
        "NSPhotoLibraryUsageDescription": "We access your photos to scan wine labels."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0a2e"
      },
      "package": "com.winelist.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        { "cameraPermission": "Allow Wine List to access your camera to scan wine labels." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow Wine List to access your photos to scan wine labels." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "winelist"
  }
}
